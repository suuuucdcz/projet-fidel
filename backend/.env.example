# Copy this file to backend/.env and fill in real values. NEVER commit the real .env.

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-or-anon-key

# --- Google Wallet ---
GOOGLE_ISSUER_ID=3388000000023151997
# Either point to a service-account JSON file...
GOOGLE_APPLICATION_CREDENTIALS=service_account.json
# ...or inline the JSON (preferred on Render — paste the whole file content on one line):
# GOOGLE_CREDENTIALS_JSON={"type":"service_account", ...}

# --- CORS ---
# Comma-separated list of allowed front-end origins (no trailing slash).
ALLOWED_ORIGINS=https://projet-fidel.vercel.app,http://localhost:5173

# --- Agency admin guard ---
# Shared secret required (header X-Admin-Token) to access /dashboard/admin/* endpoints.
# The dashboard prompts for it once. If left empty, the guard is DISABLED (not recommended).
ADMIN_TOKEN=change-me-to-a-long-random-string
